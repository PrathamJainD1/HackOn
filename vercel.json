{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/upload", "destination": "api/index.py" },
    { "source": "/progress", "destination": "api/index.py" },
    { "source": "/download", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
